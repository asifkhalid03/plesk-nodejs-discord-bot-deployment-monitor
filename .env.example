PORT=3000
DATABASE_PATH=./data/app.db

# Required. Create at least 32 random bytes. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Optional. Enables Discord messages, channel clearing, and report bot features.
# DISCORD_TOKEN is also supported if you already use that name.
DISCORD_BOT_TOKEN=
# DISCORD_TOKEN=

# Optional. The UI can resolve channel names when the bot has cache/access.
# GUILD_ID is also supported if you already use that name.
DISCORD_GUILD_ID=
# GUILD_ID=

# Optional. Required only for Daily Reports Bot feature.
DISCORD_CLIENT_ID=
DAILY_REPORTS_CHANNEL_ID=
REPORTS_DOWNLOAD_CHANNEL_ID=
REPORT_BOT_AUTO_START=false

# Optional examples for your own notes. Add these channel IDs as watcher
# Discord channel values in the UI when creating watchers.
# DAILY_REPORTS_CHANNEL_ID=
# REPORTS_DOWNLOAD_CHANNEL_ID=

# Defaults
DEFAULT_POLL_INTERVAL_SECONDS=2
WEBHOOK_TRIGGER_POLL_INTERVAL_SECONDS=10
REMOTE_CONNECT_TIMEOUT_MS=30000
FTP_VERBOSE=false
MAX_DISCORD_MESSAGE_LENGTH=1900

# If one poll reads this many new lines, send one .log attachment instead
# of many Discord messages.
LARGE_LOG_ATTACHMENT_LINE_THRESHOLD=999999

# Compress large log attachments to avoid Discord showing a slow inline preview.
COMPRESS_LARGE_LOG_ATTACHMENTS=true

# A new Discord code block/log attachment starts when this text appears.
DEPLOYMENT_BLOCK_START_TEXT=Deployment started:
DEPLOYMENT_BLOCK_END_TEXT=Deployment finished
BUFFER_DEPLOYMENT_BLOCKS=false
DEPLOYMENT_BLOCK_IDLE_FLUSH_SECONDS=0
DEPLOYMENT_BLOCK_FORCE_ATTACHMENT=false

# Optional Web UI login. Leave email or password empty to disable login.
UI_LOGIN_EMAIL=admin@example.com
UI_LOGIN_PASSWORD=
UI_SESSION_SECRET=
ALLOW_REMOTE_SETUP=false

# Optional IP restriction for the web UI/API.
# Set TRUST_PROXY=true when running behind a trusted reverse proxy.
IP_RESTRICT=false
IP_ALLOWLIST=127.0.0.1,::1
TRUST_PROXY=false
